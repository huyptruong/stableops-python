OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (used if OPENAI_API_KEY is not set)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Optional: max tokens per workflow
# MAX_TOKENS_SOCIAL_POST=512
# MAX_TOKENS_NEWSLETTER=1024
# MAX_TOKENS_GRANT=2048

# Optional: override paths (defaults: ./data and ./data/app.db)
# DATA_DIR=/path/to/data
# SQLITE_PATH=/path/to/app.db
